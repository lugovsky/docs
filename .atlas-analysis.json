  "keyFeatures": [
    "Deploy multi-service applications from a single compartment.yml descriptor",
    "Zero-downtime deployments with promote and rollback",
    "Per-environment and per-service runtime variable management",
    "On-premises self-hosted installation via Docker",
    "SSO via OIDC (Google and generic providers)",
    "Role-based access control (admin, deployer, readonly, viewer)",
    "Automatic build detection: Dockerfile or Railpack",
    "Browser-facing proxy routing via compartment.routes.yml",
    "Managed domain allocation for on-prem installs",
    "CLI with JSON output for CI/CD integration"
  ],
  "publicApiSurface": [
    "compartment init",
    "compartment deploy",
    "compartment status",
    "compartment logs",
    "compartment inspect",
